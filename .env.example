# Copy to .env and fill in values: cp .env.example .env

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Required — generate a long random string in production
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Public URLs (emails, Stripe success/cancel redirects, CORS)
# APP_URL = where this API is reachable (no trailing slash)
APP_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
# Where users open the React app (emails links, offer accept buttons context)
FRONTEND_ORIGIN=http://localhost:5173
# Extra allowed CORS origins, comma-separated (optional)
# CORS_ORIGINS=https://staging.example.com

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=by_excellence
# DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock
DB_CONNECTION_LIMIT=10

# SMTP (transactional: confirmations, statuts, rappels)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="By Excellence <noreply@yourdomain.com>"
# Optional: where contact form messages are delivered (defaults to SMTP_USER)
# CONTACT_INBOX_EMAIL=support@yourdomain.com

# Stripe — https://dashboard.stripe.com/apikeys
# Test: sk_test_... → Checkout sandbox + paiement “instantané” côté app (comme Base44)
# Live: sk_live_... → vraies sessions Checkout ; webhook obligatoire pour marquer payé
STRIPE_SECRET_KEY=
# Webhook signing secret — https://dashboard.stripe.com/webhooks
# Endpoint URL: {API_BASE_URL}/api/stripe/webhook  (ex. https://api.votredomaine.com/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=

# Commission plateforme (%)
COMMISSION_STANDARD_PERCENT=15
COMMISSION_PREMIUM_DEFAULT_PERCENT=20

# Uploads (dev: local)
UPLOAD_DRIVER=local
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# S3-compatible (production optionnel)
# UPLOAD_DRIVER=s3
# UPLOAD_BUCKET=
# UPLOAD_REGION=us-east-1
# UPLOAD_ENDPOINT=
# UPLOAD_ACCESS_KEY=
# UPLOAD_SECRET_KEY=
# UPLOAD_PUBLIC_BASE_URL=https://cdn.example.com
# UPLOAD_KEY_PREFIX=by-excellence

# Gandi / hébergement (production)
# GANDI=your-hostname.example.com
